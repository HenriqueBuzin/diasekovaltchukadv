{
  "name": "diasekovaltchukadv-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "build": "tsc --noEmit && vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "format:frontend": "prettier --write \"frontend/**/*.{ts,tsx,css,html}\" \"*.{js,ts,json}\" \"tests/e2e/**/*.js\"",
    "format:frontend:check": "prettier --check \"frontend/**/*.{ts,tsx,css,html}\" \"*.{js,ts,json}\" \"tests/e2e/**/*.js\"",
    "format:frontend:files": "prettier --write",
    "lint:frontend": "eslint .",
    "lint:frontend:files": "eslint",
    "typecheck:frontend": "tsc --noEmit",
    "test:frontend": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test": "npm run format:frontend:check && npm run lint:frontend && npm run typecheck:frontend && npm run test:frontend && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-simple-import-sort": "14.0.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "dependencies": {
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
