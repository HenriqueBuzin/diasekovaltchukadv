{
  "name": "diasekovaltchukadv-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "format:frontend": "prettier --write \"**/*.js\"",
    "format:frontend:check": "prettier --check \"**/*.js\"",
    "format:frontend:files": "prettier --write",
    "lint:frontend": "eslint .",
    "lint:frontend:files": "eslint",
    "test:frontend": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test": "npm run format:frontend:check && npm run lint:frontend && npm run test:frontend && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.55.1",
    "@vitest/coverage-v8": "3.2.7",
    "eslint": "9.39.5",
    "eslint-plugin-import": "2.32.0",
    "globals": "17.7.0",
    "jsdom": "26.1.0",
    "prettier": "3.9.5",
    "vitest": "3.2.7"
  }
}
