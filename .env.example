# .env.example

# -------------------------------
# Flask
# -------------------------------
FLASK_SECRET_KEY=
FLASK_DEBUG=

# -------------------------------
# Email (exemplo com Gmail)
# -------------------------------
MAIL_SERVER=
MAIL_PORT=
MAIL_USE_TLS=
MAIL_USE_SSL=
MAIL_USERNAME=
MAIL_PASSWORD=

# -------------------------------
# Contato
# -------------------------------
CONTACT_EMAIL=
WHATS_NUMBER=

SOCIAL_FB_URL=
SOCIAL_IG_URL=

# Pode ter vários separados por vírgula
CONTACT_TO=

# -------------------------------
# CAPTCHA
# -------------------------------
CAPTCHA_ENABLED=

# Ordem de fallback carregada pelo frontend e validada pelo backend.
# Valores suportados: turnstile, recaptcha, hcaptcha
CAPTCHA_PROVIDERS=turnstile
CAPTCHA_TIMEOUT_SECONDS=5

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google reCAPTCHA v2 checkbox
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# hCaptcha
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
